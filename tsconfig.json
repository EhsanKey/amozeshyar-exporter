{
  "compilerOptions": {
    "target": "es2024",
    "module": "es6",
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "lib": ["ES2020", "DOM"],
    "types": ["chrome"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
